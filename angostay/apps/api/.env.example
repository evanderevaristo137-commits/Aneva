# ── Núcleo ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:3000
DATABASE_URL=postgresql://angostay:angostay@localhost:5432/angostay
REDIS_URL=redis://localhost:6379

# ── Autenticação ────────────────────────────────────────
JWT_ACCESS_SECRET=troque-me-access
JWT_REFRESH_SECRET=troque-me-refresh
JWT_ACCESS_TTL=900          # 15 min
JWT_REFRESH_TTL=2592000     # 30 dias
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Storage (um dos dois) ───────────────────────────────
CLOUDINARY_URL=
AWS_S3_BUCKET=
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Pagamentos (sandbox) ────────────────────────────────
MCX_EXPRESS_API_URL=
MCX_EXPRESS_TOKEN=
MCX_EXPRESS_WEBHOOK_SECRET=
UNITEL_MONEY_API_URL=
UNITEL_MONEY_TOKEN=
UNITEL_MONEY_WEBHOOK_SECRET=
AFRIMONEY_API_URL=
AFRIMONEY_TOKEN=
AFRIMONEY_WEBHOOK_SECRET=
CARD_GATEWAY_API_URL=
CARD_GATEWAY_KEY=
CARD_GATEWAY_WEBHOOK_SECRET=

# ── Comissões ───────────────────────────────────────────
SERVICE_FEE_PERCENT=10      # comissão do hóspede
HOST_COMMISSION_PERCENT=3   # comissão do anfitrião

# ── Notificações ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_GATEWAY_URL=
SMS_GATEWAY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
